# MongoDB — same variable name as a typical `dbConnection.js` setup (`CONNECTION_STRING`).
# The path after the host is your database name (case-sensitive, e.g. Ayush-portfolio).
#
# Local:
CONNECTION_STRING=mongodb://127.0.0.1:27017/Ayush-portfolio
#
# Also supported: MONGODB_URI (if you already use that name elsewhere).
#
# Atlas example:
# CONNECTION_STRING=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/Ayush-portfolio?retryWrites=true&w=majority

# Allowed browser origins for CORS (comma-separated). Add every origin you use (port included), e.g. Next on 3001.
FRONTEND_ORIGIN=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001

# API port (Express listen)
PORT=5001

# Admin login — same route pattern as a typical user API: POST /api/users/login, GET /api/users/current
# Email + password must match these (defaults for email if unset: admin@portfolio.local).
ADMIN_EMAIL=admin@portfolio.local
ADMIN_PASSWORD=change-me-in-production
# JWT signing (same idea as validateTokenHandler + login in your other project).
ACCESS_TOKEN_SECRET=change-me-use-a-long-random-string
# Optional JWT expiry for admin token (default 30m).
# ADMIN_ACCESS_EXPIRES_IN=30m
